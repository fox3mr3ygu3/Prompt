# quick-conf.app — environment reference
# Copy to .env and fill in. Values here are safe defaults for local dev.

# --- App ---
APP_ENV=dev
APP_DEBUG=true
APP_NAME=quick-conf

# --- Postgres ---
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DSN=postgresql+psycopg://app:app@postgres:5432/app

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Meilisearch ---
MEILI_URL=http://meili:7700
MEILI_MASTER_KEY=devmasterkey_change_me

# --- Auth ---
JWT_SECRET=devsecret_change_me_in_prod
JWT_ALGO=HS256
JWT_TTL_MINUTES=60

# --- Tickets ---
TICKET_SIGNING_KEY=devticketsecret_change_me
SEAT_HOLD_TTL_SECONDS=300

# --- Payments (mock only for now) ---
PAYMENT_PROVIDER=mock
PAYMENT_MOCK_DELAY_MS=200
PAYMENT_MOCK_FAIL_RATE=0.0

# --- Rate limiter ---
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=quick-conf-backend
OTEL_TRACES_SAMPLER=parentbased_always_on

# --- Frontend ---
VITE_API_BASE=/api
VITE_WS_BASE=/ws
