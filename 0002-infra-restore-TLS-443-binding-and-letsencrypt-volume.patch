From 81fb2f4e6166fe5d8a208aaee8bd30bac2d4a41a Mon Sep 17 00:00:00 2001
From: Deploy Bot <deploy@quick-conf.app>
Date: Wed, 6 May 2026 06:56:07 +0000
Subject: [PATCH 2/2] infra: restore TLS 443 binding and letsencrypt volume
 mount

---
 .gitignore              |  1 +
 docker-compose.prod.yml |  2 ++
 infra/nginx/nginx.conf  | 51 +++++++++++++++++++----------------------
 3 files changed, 27 insertions(+), 27 deletions(-)

diff --git a/.gitignore b/.gitignore
index be055d4..180284a 100644
--- a/.gitignore
+++ b/.gitignore
@@ -52,3 +52,4 @@ prometheus-data/
 
 # OS
 *.log
+*.bak
diff --git a/docker-compose.prod.yml b/docker-compose.prod.yml
index bfd6960..e79bb79 100644
--- a/docker-compose.prod.yml
+++ b/docker-compose.prod.yml
@@ -114,8 +114,10 @@ services:
       - ./infra/nginx/nginx.conf:/usr/local/openresty/nginx/conf/nginx.conf:ro
       - ./infra/nginx/lua:/etc/nginx/lua:ro
       - frontend-dist:/var/www/html:ro
+      - /etc/letsencrypt:/etc/letsencrypt:ro
     ports:
       - "80:80"
+      - "443:443"
     healthcheck:
       test: ["CMD", "wget", "-q", "-O", "-", "http://127.0.0.1/healthz"]
       interval: 10s
diff --git a/infra/nginx/nginx.conf b/infra/nginx/nginx.conf
index 3b6e00a..072a844 100644
--- a/infra/nginx/nginx.conf
+++ b/infra/nginx/nginx.conf
@@ -1,16 +1,7 @@
-# quick-conf.app — edge gateway.
-#
-# - TLS termination (configured at deploy time; commented in dev for HTTP-only)
-# - SPA fallback to /index.html for any non-/api, non-/ws path
-# - Round-robin across two FastAPI replicas (R8)
-# - Custom token-bucket rate limiter at the edge (R11), implemented in Lua,
-#   backed by Redis. See ./lua/token_bucket.lua and ../../docs/adr/ADR-002.
-
 worker_processes auto;
 error_log /dev/stderr warn;
 pid /tmp/nginx.pid;
 
-# Make these visible to os.getenv() inside Lua workers.
 env RATE_LIMIT_RPS;
 env RATE_LIMIT_BURST;
 env REDIS_HOST;
@@ -35,27 +26,20 @@ http {
     server_tokens off;
     client_max_body_size 4m;
 
-    # Docker's embedded DNS — required so the Lua resty.redis client can
-    # resolve the `redis` service hostname at request time.
     resolver 127.0.0.11 ipv6=off valid=30s;
 
-    # ── Lua: shared dict for fail-open accounting + Redis client ─────────────
     lua_package_path  "/etc/nginx/lua/?.lua;;";
     lua_shared_dict ratelimit_state 10m;
     init_by_lua_block {
         require "token_bucket"
     }
 
-    # ── Upstream: two FastAPI replicas, round-robin ──────────────────────────
     upstream backend {
-        # Setting `least_conn` would load-balance by inflight connections; we
-        # keep RR for visibility and because all routes are short-lived.
         server backend1:8000 max_fails=3 fail_timeout=10s;
         server backend2:8000 max_fails=3 fail_timeout=10s;
         keepalive 32;
     }
 
-    # WebSocket upgrade map.
     map $http_upgrade $connection_upgrade {
         default upgrade;
         ''      close;
@@ -63,13 +47,31 @@ http {
 
     server {
         listen 80;
-        server_name _;
+        server_name quick-conf.app www.quick-conf.app;
+
+        location /.well-known/acme-challenge/ {
+            root /var/www/certbot;
+        }
+
+        location / {
+            return 301 https://$host$request_uri;
+        }
+    }
+
+    server {
+        listen 443 ssl;
+        http2 on;
+        server_name quick-conf.app www.quick-conf.app;
+
+        ssl_certificate     /etc/letsencrypt/live/quick-conf.app/fullchain.pem;
+        ssl_certificate_key /etc/letsencrypt/live/quick-conf.app/privkey.pem;
+
+        ssl_protocols TLSv1.2 TLSv1.3;
+        ssl_ciphers HIGH:!aNULL:!MD5;
+        ssl_prefer_server_ciphers on;
+        ssl_session_cache shared:SSL:10m;
+        ssl_session_timeout 10m;
 
-        # Rate-limit hot endpoints: hold, order create, and gate scan. Costs
-        # 1 token per request; falls open if Redis is unreachable (logged +
-        # counted in shared dict). The previous form ``|orders`` matched a
-        # nonexistent ``/api/orders`` and missed the actual create-order
-        # path ``/api/events/{ref}/orders``.
         location ~ ^/api/(events/[^/]+/(hold|orders)|tickets/scan) {
             access_by_lua_block {
                 local tb = require "token_bucket"
@@ -86,7 +88,6 @@ http {
             proxy_pass http://backend;
         }
 
-        # WebSocket — bypass the rate limiter (ping traffic is benign).
         location /ws/ {
             proxy_http_version 1.1;
             proxy_set_header Upgrade $http_upgrade;
@@ -96,8 +97,6 @@ http {
             proxy_pass http://backend;
         }
 
-        # All other API traffic — proxied without rate-limit (still subject
-        # to FastAPI auth).
         location /api/ {
             proxy_set_header Host $host;
             proxy_set_header X-Real-IP $remote_addr;
@@ -106,12 +105,10 @@ http {
             proxy_pass http://backend;
         }
 
-        # Swagger / OpenAPI passthrough.
         location ~ ^/(docs|openapi.json|healthz|readyz) {
             proxy_pass http://backend;
         }
 
-        # SPA fallback. Frontend container exposes /var/www/html as the build.
         root /var/www/html;
         index index.html;
         location / {
-- 
