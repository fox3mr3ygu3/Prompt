{
  "uid": "qc-hold-pay-confirm",
  "title": "quick-conf — hold → pay → confirm",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["quick-conf"],
  "timezone": "browser",
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Request rate (per route)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (http_route) (rate(http_server_request_duration_seconds_count[1m]))",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 latency (per route)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, http_route) (rate(http_server_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Booking logs (Loki)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "{service_name=\"quick-conf-backend\"} |~ \"hold|order|scan\""
        }
      ]
    },
    {
      "type": "traces",
      "title": "Recent traces (Tempo)",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 10 },
      "targets": [
        {
          "queryType": "search",
          "tags": "service.name=quick-conf-backend"
        }
      ]
    }
  ]
}
